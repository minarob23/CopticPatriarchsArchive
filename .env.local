
# PostgreSQL configuration for Windows
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/coptic_patriarchs

# Optional: Add your Gemini API key if you want AI features
# Get your key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Session secret for local development
SESSION_SECRET=local-dev-secret-key-for-windows

# Environment settings
NODE_ENV=development
PORT=5000

# Suppress console messages
DOTENV_CONFIG_SILENT=true
NODE_NO_WARNINGS=1
