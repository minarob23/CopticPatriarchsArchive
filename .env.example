# إعدادات قاعدة البيانات المحلية
# ====================================

# للاستخدام مع PostgreSQL (مستحسن)
DATABASE_URL=postgresql://username:password@localhost:5432/coptic_patriarchs

# أو للاستخدام مع SQLite (أسهل للبداية)
# DATABASE_URL=file:./local.db
# USE_SQLITE=true

# مفتاح Google Gemini API للذكاء الاصطناعي
# ========================================
# احصل على مفتاحك من: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# إعدادات الجلسات (اختياري)
# ============================
SESSION_SECRET=your_random_session_secret_here

# إعدادات البيئة
# ==============
NODE_ENV=development
PORT=5000

# ملاحظات:
# --------
# 1. انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# 2. لا تشارك ملف .env مع أحد
# 3. أضف .env إلى .gitignore إذا كنت تستخدم Git